{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrackMLN",
  "version": "1.1.0",
  "identifier": "com.trackmln.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TrackMLN",
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "maximizable": false,
        "skipTaskbar": true,
        "visible": false,
        "width": 1920,
        "height": 1080
      }
    ]
  }
}
