{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrackMLN Installer",
  "version": "1.1.0",
  "identifier": "com.trackmln.installer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TrackMLN Installer",
        "width": 1220,
        "height": 620,
        "minWidth": 1040,
        "minHeight": 560,
        "resizable": true,
        "maximizable": true,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": ["icons/icon.ico"],
    "resources": ["assets/app"]
  }
}
